# Supabase (yeni projenizin değerleri)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vertex AI (kurumsal altyapıda Gemini)
# Yerel geliştirme: indirilen servis hesabı JSON dosyasının yolunu verin
GOOGLE_APPLICATION_CREDENTIALS=./your-service-account.json
# Üretim (Vercel): bunun yerine JSON dosyasının tüm içeriğini tek satır olarak yapıştırın
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Uygulama temel URL'si (yükleme işlemi, işleyici rotasını çağırmak için kullanır)
NEXT_PUBLIC_APP_URL=http://localhost:3000
